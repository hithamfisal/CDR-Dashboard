# Local API server port. Vercel ignores this and uses /api functions automatically.
CDR_API_PORT=4100
CDR_ALLOWED_ORIGIN=http://127.0.0.1:5173,http://127.0.0.1:5177,http://127.0.0.1:5178,http://127.0.0.1:5188,http://localhost:5173,http://localhost:5177,http://localhost:5178,http://localhost:5188
NODE_ENV=development

# MySQL connection. For Vercel, use a cloud/public MySQL host, not 127.0.0.1.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=replace-with-a-strong-mysql-password
MYSQL_DATABASE=cdr_dashboard
MYSQL_CONNECTION_LIMIT=10

# Set to 1 on Vercel if the cloud database already exists or the user cannot CREATE DATABASE.
CDR_SKIP_CREATE_DATABASE=0

# Set a long random value in production/Vercel.
CDR_SESSION_SECRET=replace-with-a-long-random-secret-at-least-32-characters
CDR_SESSION_TTL_HOURS=8
CDR_MAX_FAILED_LOGINS=5
CDR_MAX_JSON_BYTES=15000000

# Optional local-only bootstrap. Leave disabled in production.
# If enabled, all three passwords must be set and at least 12 characters.
CDR_SEED_DEFAULT_USERS=0
CDR_DEFAULT_ADMIN_USERNAME=admin
CDR_DEFAULT_ADMIN_PASSWORD=
CDR_DEFAULT_CUSTOMER_ADMIN_USERNAME=customeradmin
CDR_DEFAULT_CUSTOMER_ADMIN_PASSWORD=
CDR_DEFAULT_CUSTOMER_USERNAME=customer
CDR_DEFAULT_CUSTOMER_PASSWORD=
